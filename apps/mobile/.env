# apps/mobile/.env
#
# ⚠️  SAU KHI SỬA FILE NÀY → BẮT BUỘC chạy lại: pnpm start --clear
#     (Metro cache lại env vars, không clear sẽ dùng giá trị cũ)
#
# ─── CHỌN 1 TRONG 3 DÒNG BÊN DƯỚI, BỎ COMMENT DÒNG PHÙ HỢP ───────────────

# [1] Expo Web (localhost:8081) hoặc Android Emulator trên cùng máy tính:
EXPO_PUBLIC_API_URL=http://192.168.0.101:4000

# [2] Điện thoại thật (iOS/Android) - cùng WiFi với máy tính chạy backend:
#     Windows: ipconfig → IPv4 Address
#     macOS  : ipconfig getifaddr en0
# EXPO_PUBLIC_API_URL=http://192.168.3.44:4000

# [3] Production:
# EXPO_PUBLIC_API_URL=https://api.agriscan.ai
