# apps/mobile/.env
# 
# ĐỔI IP NÀY thành IP máy tính của bạn trên mạng WiFi nội bộ
#
# Cách lấy IP:
#   Windows : mở CMD → ipconfig → xem "IPv4 Address"
#   macOS   : mở Terminal → ifconfig | grep "inet " | grep -v 127
#   Linux   : hostname -I
#
# Lưu ý: Điện thoại và máy tính PHẢI cùng WiFi
#
# Android Emulator (máy ảo trên cùng máy tính):
EXPO_PUBLIC_API_URL=http://192.168.3.44:4000

#
# Thiết bị thật (điện thoại): thay IP bên dưới
# EXPO_PUBLIC_API_URL=http://192.168.1.xxx:4000
#
# Production:
# EXPO_PUBLIC_API_URL=https://api.agriscan.ai
